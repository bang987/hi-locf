<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hi.locf.feature.locf.mapper.LocfTargetContractMapper">

    <resultMap id="locfTargetContractResultMap" type="com.hi.locf.feature.locf.entity.LocfTargetContract">
        <id property="targetId" column="TARGET_ID"/>
        <result property="batchExecutionId" column="BATCH_EXECUTION_ID"/>
        <result property="contractId" column="CONTRACT_ID"/>
        <result property="contractNo" column="CONTRACT_NO"/>
        <result property="customerId" column="CUSTOMER_ID"/>
        <result property="customerName" column="CUSTOMER_NAME"/>
        <result property="productCode" column="PRODUCT_CODE"/>
        <result property="repaymentType" column="REPAYMENT_TYPE"/>
        <result property="principalAmt" column="PRINCIPAL_AMT"/>
        <result property="feeAmt" column="FEE_AMT"/>
        <result property="directCostAmt" column="DIRECT_COST_AMT"/>
        <result property="annualNominalRate" column="ANNUAL_NOMINAL_RATE"/>
        <result property="executionDate" column="EXECUTION_DATE"/>
        <result property="maturityDate" column="MATURITY_DATE"/>
        <result property="termInMonths" column="TERM_IN_MONTHS"/>
    </resultMap>

    <delete id="deleteTargetContractsByBatchExecutionId">
        DELETE FROM LOCF_TARGET_CONTRACT
         WHERE BATCH_EXECUTION_ID = #{batchExecutionId}
    </delete>

    <insert id="insertTargetContracts" statementType="CALLABLE">
        <!--
            원천 계약/금리/잔액 테이블에서 LOCF 배치 대상 계약을 한 번에 적재하는
            오라클 프로시저를 호출한다.
        -->
        { CALL PRC_LOCF_INSERT_TARGET_CONTRACTS(
            #{batchExecutionId},
            #{baseDate}
        ) }
    </insert>

    <select id="findTargetContractsByBatchExecutionId" resultMap="locfTargetContractResultMap">
        <!--
            방금 적재한 대상 계약을 다시 읽어 이후 CASHFLOW/EIR/상각 step의 입력으로 사용한다.
            화면에 고객명을 함께 보여주기 위해 고객마스터와 조인한다.
        -->
        SELECT t.TARGET_ID,
               t.BATCH_EXECUTION_ID,
               t.CONTRACT_ID,
               t.CONTRACT_NO,
               t.CUSTOMER_ID,
               cm.CUSTOMER_NAME,
               t.PRODUCT_CODE,
               t.REPAYMENT_TYPE,
               t.PRINCIPAL_AMT,
               t.FEE_AMT,
               t.DIRECT_COST_AMT,
               t.ANNUAL_NOMINAL_RATE,
               t.EXECUTION_DATE,
               t.MATURITY_DATE,
               t.TERM_IN_MONTHS
          FROM LOCF_TARGET_CONTRACT t,
               CUSTOMER_MASTER cm
         WHERE cm.CUSTOMER_ID(+) = t.CUSTOMER_ID
           AND t.BATCH_EXECUTION_ID = #{batchExecutionId}
         ORDER BY t.CONTRACT_ID ASC
    </select>

    <select id="countTargetContracts" resultType="long">
        SELECT COUNT(*)
          FROM LOCF_TARGET_CONTRACT
         WHERE BATCH_EXECUTION_ID = #{batchExecutionId}
    </select>
</mapper>
