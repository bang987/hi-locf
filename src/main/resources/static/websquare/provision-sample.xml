<?xml version="1.0" encoding="UTF-8"?>
<w2:root
        xmlns:w2="http://www.inswave.com/websquare"
        xmlns:xf="http://www.w3.org/2002/xforms">

    <!--
        학습용 WebSquare 충당금 화면 예제

        목적:
        1. 충당금 배치 실행
        2. 배치 이력 / step 이력 조회
        3. 계약별 Stage / EAD / PD / LGD / ECL 결과 조회
        4. 기준일자별 상품 / Stage 요약 조회
        
        scwin :현재 화면 함수 모음
		$p:현재 페이지 객체, 컴포넌트/데이터셋/API 찾는 출발점
			.getComponentById("...") :화면 컴포넌트 찾기
			.getSubmission("...") :API 호출 객체 찾기
			.getDataCollection("...") : DataMap / DataList 찾기
    -->

    <w2:head>
        <w2:type>PAGE</w2:type>
        <w2:model>
            <w2:dataCollection>
                <!-- 배치 실행 요청값을 담는 DataMap -->
                <w2:dataMap id="dmBatchRunRequest" baseNode="map">
                    <w2:key id="baseDate" dataType="text" value="2026-01-10"/>
                    <w2:key id="batchType" dataType="text" value="MANUAL"/>
                </w2:dataMap>

                <!-- 배치 실행 결과 1건을 담는 DataMap -->
                <w2:dataMap id="dmBatchRunResult" baseNode="map"/>

                <!-- 개별평가 대상 등록 요청값을 담는 DataMap -->
                <w2:dataMap id="dmIndividualEvalTargetRequest" baseNode="map">
                    <w2:key id="baseDate" dataType="text" value="2026-01-10"/>
                    <w2:key id="contractNo" dataType="text" value="LN-2026-000001"/>
                    <w2:key id="evalReasonCode" dataType="text" value="DEFAULT"/>
                    <w2:key id="evalReasonDetail" dataType="text" value=""/>
                    <w2:key id="recoveryExpectedAmt" dataType="text" value=""/>
                    <w2:key id="discountRate" dataType="text" value=""/>
                    <w2:key id="activeYn" dataType="text" value="Y"/>
                </w2:dataMap>

                <!-- 배치 실행 이력 목록 -->
                <w2:dataList id="dlBatchHistory" repeatNode="row">
                    <w2:columnInfo>
                        <w2:column id="batchRunNo" dataType="text"/>
                        <w2:column id="baseDate" dataType="text"/>
                        <w2:column id="batchType" dataType="text"/>
                        <w2:column id="statusCode" dataType="text"/>
                        <w2:column id="targetCount" dataType="number"/>
                        <w2:column id="processedCount" dataType="number"/>
                        <w2:column id="errorCount" dataType="number"/>
                    </w2:columnInfo>
                </w2:dataList>

                <!-- 배치 Step 실행 이력 목록 -->
                <w2:dataList id="dlStepHistory" repeatNode="row">
                    <w2:columnInfo>
                        <w2:column id="stepName" dataType="text"/>
                        <w2:column id="statusCode" dataType="text"/>
                        <w2:column id="processedCount" dataType="number"/>
                        <w2:column id="startedAt" dataType="text"/>
                        <w2:column id="finishedAt" dataType="text"/>
                    </w2:columnInfo>
                </w2:dataList>

                <!-- 계약별 충당금 결과 목록 -->
                <w2:dataList id="dlContractResults" repeatNode="row">
                    <w2:columnInfo>
                        <w2:column id="contractNo" dataType="text"/>
                        <w2:column id="customerName" dataType="text"/>
                        <w2:column id="productCode" dataType="text"/>
                        <w2:column id="stageCode" dataType="text"/>
                        <w2:column id="stageReason" dataType="text"/>
                        <w2:column id="carryingAmount" dataType="number"/>
                        <w2:column id="eadAmount" dataType="number"/>
                        <w2:column id="oneYearPdRate" dataType="number"/>
                        <w2:column id="lifetimePdRate" dataType="number"/>
                        <w2:column id="lgdRate" dataType="number"/>
                        <w2:column id="recoveryRate" dataType="number"/>
                        <w2:column id="eclAmount" dataType="number"/>
                    </w2:columnInfo>
                </w2:dataList>

                <!-- 상품코드 / Stage 기준 요약 목록 -->
                <w2:dataList id="dlSummary" repeatNode="row">
                    <w2:columnInfo>
                        <w2:column id="baseDate" dataType="text"/>
                        <w2:column id="productCode" dataType="text"/>
                        <w2:column id="stageCode" dataType="text"/>
                        <w2:column id="contractCount" dataType="number"/>
                        <w2:column id="totalCarryingAmount" dataType="number"/>
                        <w2:column id="totalEadAmount" dataType="number"/>
                        <w2:column id="totalEclAmount" dataType="number"/>
                    </w2:columnInfo>
                </w2:dataList>

                <!-- 고객유형 / 세그먼트 / Stage 기준 요약 목록 -->
                <w2:dataList id="dlSegmentSummary" repeatNode="row">
                    <w2:columnInfo>
                        <w2:column id="baseDate" dataType="text"/>
                        <w2:column id="customerType" dataType="text"/>
                        <w2:column id="segmentCode" dataType="text"/>
                        <w2:column id="stageCode" dataType="text"/>
                        <w2:column id="contractCount" dataType="number"/>
                        <w2:column id="totalCarryingAmount" dataType="number"/>
                        <w2:column id="totalEadAmount" dataType="number"/>
                        <w2:column id="totalEclAmount" dataType="number"/>
                    </w2:columnInfo>
                </w2:dataList>

                <!-- 개별평가 등록 전 참고용 계약 조회 결과 -->
                <w2:dataList id="dlIndividualEvalContract" repeatNode="row">
                    <w2:columnInfo>
                        <w2:column id="contractNo" dataType="text"/>
                        <w2:column id="customerName" dataType="text"/>
                        <w2:column id="productCode" dataType="text"/>
                        <w2:column id="stageCode" dataType="text"/>
                        <w2:column id="stageReason" dataType="text"/>
                        <w2:column id="carryingAmount" dataType="number"/>
                        <w2:column id="eadAmount" dataType="number"/>
                        <w2:column id="oneYearPdRate" dataType="number"/>
                        <w2:column id="lifetimePdRate" dataType="number"/>
                        <w2:column id="lgdRate" dataType="number"/>
                        <w2:column id="recoveryRate" dataType="number"/>
                        <w2:column id="eclAmount" dataType="number"/>
                    </w2:columnInfo>
                </w2:dataList>

                <!-- 등록된 개별평가 대상 목록 -->
                <w2:dataList id="dlIndividualEvalTargets" repeatNode="row">
                    <w2:columnInfo>
                        <w2:column id="individualTargetId" dataType="number"/>
                        <w2:column id="baseDate" dataType="text"/>
                        <w2:column id="contractId" dataType="number"/>
                        <w2:column id="contractNo" dataType="text"/>
                        <w2:column id="customerName" dataType="text"/>
                        <w2:column id="productCode" dataType="text"/>
                        <w2:column id="evalReasonCode" dataType="text"/>
                        <w2:column id="evalReasonDetail" dataType="text"/>
                        <w2:column id="recoveryExpectedAmt" dataType="number"/>
                        <w2:column id="discountRate" dataType="number"/>
                        <w2:column id="activeYn" dataType="text"/>
                        <w2:column id="createdAt" dataType="text"/>
                        <w2:column id="updatedAt" dataType="text"/>
                    </w2:columnInfo>
                </w2:dataList>
            </w2:dataCollection>

            <!-- 충당금 배치 실행 -->
            <xf:submission id="sbmRunBatch"
                           ref="data:dmBatchRunRequest"
                           action="http://localhost:8080/hi-locf/api/v1/provision/batches/run"
                           method="post"
                           mediatype="application/json"/>

            <!-- 배치 이력 조회 -->
            <xf:submission id="sbmBatchHistory"
                            method="get"
                            mediatype="application/json"/>

            <!-- Step 이력 조회 -->
            <xf:submission id="sbmStepHistory"
                           method="get"
                           mediatype="application/json"/>

            <!-- 계약별 충당금 결과 조회 -->
            <xf:submission id="sbmContractResult"
                           method="get"
                           mediatype="application/json"/>

            <!-- 기준일자별 상품 / Stage 요약 조회 -->
            <xf:submission id="sbmSummary"
                           method="get"
                           mediatype="application/json"/>

            <!-- 기준일자별 세그먼트 요약 조회 -->
            <xf:submission id="sbmSegmentSummary"
                           method="get"
                           mediatype="application/json"/>

            <!-- 개별평가 등록 전 참고 계약정보 조회 -->
            <xf:submission id="sbmIndividualEvalContract"
                           method="get"
                           mediatype="application/json"/>

            <!-- 등록된 개별평가 대상 목록 조회 -->
            <xf:submission id="sbmIndividualEvalTargets"
                           method="get"
                           mediatype="application/json"/>

            <!-- 개별평가 대상 등록 -->
            <xf:submission id="sbmCreateIndividualEvalTarget"
                           ref="data:dmIndividualEvalTargetRequest"
                           method="post"
                           mediatype="application/json"/>

            <!-- 개별평가 대상 삭제 -->
            <xf:submission id="sbmDeleteIndividualEvalTarget"
                           method="delete"
                           mediatype="application/json"/>
        </w2:model>

        <w2:script lazy="false"><![CDATA[
            // 화면 최초 진입 시 배치 이력을 먼저 조회해서 학습 흐름을 시작한다.
            function scwin.onload() {
                scwin.loadBatchHistory();
            }

            // 기준일자 / 배치유형을 DataMap에 담아 충당금 배치를 실행한다.
            scwin.runBatch = function() {
                var baseDate = $p.getComponentById("iptBaseDate").getValue();
                var request = $p.getDataCollection("dmBatchRunRequest");
                request.set("baseDate", baseDate);
                request.set("batchType", "MANUAL");
                $p.getSubmission("sbmRunBatch").send();
                
            };

            // 기준일자 조건으로 배치 실행 이력을 조회한다.
            scwin.loadBatchHistory = function() {
                var baseDate = $p.getComponentById("iptHistoryDate").getValue();
                var action = "http://localhost:8080/hi-locf/api/v1/provision/batches";
                if (baseDate) {
                    action = action + "?baseDate=" + baseDate;
                }
                $p.getSubmission("sbmBatchHistory").setAction(action);
                $p.getSubmission("sbmBatchHistory").send();
            };

            // 배치실행번호 기준으로 Step 이력을 조회한다.
            scwin.loadStepHistory = function() {
                var batchRunNo = $p.getComponentById("iptBatchRunNo").getValue();
                if (!batchRunNo) {
                    alert("배치실행번호를 입력하세요.");
                    return;
                }
                $p.getSubmission("sbmStepHistory").setAction(
                    "http://localhost:8080/hi-locf/api/v1/provision/batches/" + batchRunNo + "/steps"
                );
                $p.getSubmission("sbmStepHistory").send();
            };

            // 계약번호 기준으로 충당금 계산 결과를 조회한다.
            scwin.loadContractResult = function() {
                var contractNo = $p.getComponentById("iptContractNo").getValue();
                if (!contractNo) {
                    alert("계약번호를 입력하세요.");
                    return;
                }
                $p.getSubmission("sbmContractResult").setAction(
                    "http://localhost:8080/hi-locf/api/v1/provision/contracts/" + contractNo
                );
                $p.getSubmission("sbmContractResult").send();
            };

            // 기준일자 기준 상품 / Stage 요약을 조회한다.
            scwin.loadSummary = function() {
                var baseDate = $p.getComponentById("iptSummaryDate").getValue();
                if (!baseDate) {
                    alert("기준일자를 입력하세요.");
                    return;
                }
                $p.getSubmission("sbmSummary").setAction(
                    "http://localhost:8080/hi-locf/api/v1/provision/results/summary?baseDate=" + baseDate
                );
                $p.getSubmission("sbmSummary").send();
            };

            // 기준일자 기준 세그먼트 요약을 조회한다.
            scwin.loadSegmentSummary = function() {
                var baseDate = $p.getComponentById("iptSegmentSummaryDate").getValue();
                if (!baseDate) {
                    alert("세그먼트 요약 기준일자를 입력하세요.");
                    return;
                }
                $p.getSubmission("sbmSegmentSummary").setAction(
                    "http://localhost:8080/hi-locf/api/v1/provision/results/segment-summary?baseDate=" + baseDate
                );
                $p.getSubmission("sbmSegmentSummary").send();
            };

            // 개별평가 등록 전 참고 계약정보를 먼저 조회한다.
            scwin.loadIndividualEvalContract = function() {
                var baseDate = $p.getComponentById("iptIeBaseDate").getValue();
                var contractNo = $p.getComponentById("iptIeContractNo").getValue();
                if (!contractNo) {
                    alert("개별평가 대상 계약번호를 입력하세요.");
                    return;
                }
                $p.getSubmission("sbmIndividualEvalContract").setAction(
                    "http://localhost:8080/hi-locf/api/v1/provision/contracts/" + contractNo
                );
                $p.getSubmission("sbmIndividualEvalContract").send();
                $p.getComponentById("txtIndividualEvalStatus").setValue(
                    "기준일자 " + baseDate + " 기준으로 계약 " + contractNo + " 참고정보를 조회합니다."
                );
            };

            // 입력한 평가사유 / 예상회수금액 / 할인율을 API로 전달해 개별평가 대상을 등록한다.
            scwin.registerIndividualEvalTarget = function() {
                var baseDate = $p.getComponentById("iptIeBaseDate").getValue();
                var contractNo = $p.getComponentById("iptIeContractNo").getValue();
                var evalReasonCode = $p.getComponentById("iptEvalReasonCode").getValue();
                var evalReasonDetail = $p.getComponentById("iptEvalReasonDetail").getValue();
                var recoveryExpectedAmt = $p.getComponentById("iptRecoveryExpectedAmt").getValue();
                var discountRate = $p.getComponentById("iptDiscountRate").getValue();

                if (!contractNo) {
                    alert("계약번호를 입력하세요.");
                    return;
                }
                if (!evalReasonCode) {
                    alert("평가사유코드를 입력하세요.");
                    return;
                }

                var request = $p.getDataCollection("dmIndividualEvalTargetRequest");
                request.set("baseDate", baseDate);
                request.set("contractNo", contractNo);
                request.set("evalReasonCode", evalReasonCode);
                request.set("evalReasonDetail", evalReasonDetail);
                request.set("recoveryExpectedAmt", recoveryExpectedAmt);
                request.set("discountRate", discountRate);
                request.set("activeYn", "Y");

                $p.getSubmission("sbmCreateIndividualEvalTarget").setAction(
                    "http://localhost:8080/hi-locf/api/v1/provision/individual-targets"
                );
                $p.getSubmission("sbmCreateIndividualEvalTarget").send();
            };

            // 기준일자와 선택적 계약번호 조건으로 개별평가 대상 목록을 조회한다.
            scwin.loadIndividualEvalTargets = function() {
                var baseDate = $p.getComponentById("iptIeBaseDate").getValue();
                var contractNo = $p.getComponentById("iptIeContractNo").getValue();
                if (!baseDate) {
                    alert("기준일자를 입력하세요.");
                    return;
                }

                var action = "http://localhost:8080/hi-locf/api/v1/provision/individual-targets?baseDate=" + baseDate;
                if (contractNo) {
                    action += "&contractNo=" + contractNo;
                }

                $p.getSubmission("sbmIndividualEvalTargets").setAction(action);
                $p.getSubmission("sbmIndividualEvalTargets").send();
            };

            // 그리드에서 선택한 개별평가 대상 1건을 삭제한다.
            scwin.deleteIndividualEvalTarget = function() {
                var selectedIndex = $p.getComponentById("grdIndividualEvalTargets").getFocusedIndex();
                if (selectedIndex < 0) {
                    alert("삭제할 개별평가 대상을 선택하세요.");
                    return;
                }

                var dataList = $p.getDataCollection("dlIndividualEvalTargets");
                var individualTargetId = dataList.getRowJSON(selectedIndex).individualTargetId;

                $p.getSubmission("sbmDeleteIndividualEvalTarget").setAction(
                    "http://localhost:8080/hi-locf/api/v1/provision/individual-targets/" + individualTargetId
                );
                $p.getSubmission("sbmDeleteIndividualEvalTarget").send();
            };

            // 목록 형태 응답은 success / data 구조를 풀어 DataList에 넣는 공통 처리 함수다.
            scwin.handleListResponse = function(responseText, dataListId) {
                var response = JSON.parse(responseText);
                if (!response.success) {
                    alert(response.error ? response.error.message : "조회 중 오류가 발생했습니다.");
                    return;
                }
                $p.getDataCollection(dataListId).setJSON(response.data);
            };

            // 배치 실행 성공 후에는 배치결과 / 이력 / 요약을 연쇄 조회한다.
            scwin.handleBatchRunResponse = function(responseText) {
                var response = JSON.parse(responseText);
                if (!response.success) {
                    alert(response.error ? response.error.message : "배치 실행 중 오류가 발생했습니다.");
                    return;
                }

                var result = response.data;
                $p.getDataCollection("dmBatchRunResult").setJSON(result);
                $p.getComponentById("iptBatchRunNo").setValue(result.batchRunNo);
                $p.getComponentById("iptHistoryDate").setValue(result.baseDate);
                $p.getComponentById("iptSummaryDate").setValue(result.baseDate);

                scwin.loadBatchHistory();
                scwin.loadStepHistory();
                scwin.loadSummary();
                scwin.loadContractResult();
            };

            // 배치 실행 응답 처리
            function sbmRunBatch_submitdone(e) {
                scwin.handleBatchRunResponse(e.responseBody);
            }

            // 배치 이력 응답 처리
            function sbmBatchHistory_submitdone(e) {
                scwin.handleListResponse(e.responseBody, "dlBatchHistory");
            }

            // Step 이력 응답 처리
            function sbmStepHistory_submitdone(e) {
                scwin.handleListResponse(e.responseBody, "dlStepHistory");
            }

            // 계약별 결과 응답 처리
            function sbmContractResult_submitdone(e) {
                scwin.handleListResponse(e.responseBody, "dlContractResults");
            }

            // 상품 / Stage 요약 응답 처리
            function sbmSummary_submitdone(e) {
                scwin.handleListResponse(e.responseBody, "dlSummary");
            }

            // 세그먼트 요약 응답 처리
            function sbmSegmentSummary_submitdone(e) {
                scwin.handleListResponse(e.responseBody, "dlSegmentSummary");
            }

            // 개별평가 참고 계약 조회 후 화면 상단 참고정보를 채운다.
            function sbmIndividualEvalContract_submitdone(e) {
                var response = JSON.parse(e.responseBody);
                if (!response.success) {
                    alert(response.error ? response.error.message : "계약 조회 중 오류가 발생했습니다.");
                    return;
                }

                $p.getDataCollection("dlIndividualEvalContract").setJSON(response.data);

                var contract = response.data && response.data.length > 0 ? response.data[0] : null;
                if (!contract) {
                    $p.getComponentById("txtIndividualEvalStatus").setValue("조회 결과가 없습니다.");
                    return;
                }

                $p.getComponentById("txtIeBaseDate").setValue($p.getComponentById("iptIeBaseDate").getValue());
                $p.getComponentById("txtIeContractNo").setValue(contract.contractNo || "");
                $p.getComponentById("txtIeCustomerName").setValue(contract.customerName || "");
                $p.getComponentById("txtIeProductCode").setValue(contract.productCode || "");
                $p.getComponentById("txtIeStageCode").setValue(contract.stageCode || "");
                $p.getComponentById("txtIeStageReason").setValue(contract.stageReason || "");
                $p.getComponentById("txtIeCarryingAmount").setValue(contract.carryingAmount || "");
                $p.getComponentById("txtIeEadAmount").setValue(contract.eadAmount || "");
                $p.getComponentById("txtIeOneYearPdRate").setValue(contract.oneYearPdRate || "");
                $p.getComponentById("txtIeLifetimePdRate").setValue(contract.lifetimePdRate || "");
                $p.getComponentById("txtIeLgdRate").setValue(contract.lgdRate || "");
                $p.getComponentById("txtIeEclAmount").setValue(contract.eclAmount || "");
                $p.getComponentById("txtIndividualEvalStatus").setValue("개별평가 대상 참고 계약정보 조회가 완료되었습니다.");
                scwin.loadIndividualEvalTargets();
            }

            // 개별평가 대상 목록 응답 처리
            function sbmIndividualEvalTargets_submitdone(e) {
                scwin.handleListResponse(e.responseBody, "dlIndividualEvalTargets");
            }

            // 개별평가 대상 등록 후 상태문구를 갱신하고 목록을 다시 조회한다.
            function sbmCreateIndividualEvalTarget_submitdone(e) {
                var response = JSON.parse(e.responseBody);
                if (!response.success) {
                    alert(response.error ? response.error.message : "개별평가 대상 등록 중 오류가 발생했습니다.");
                    return;
                }

                var result = response.data;
                $p.getComponentById("txtIndividualEvalStatus").setValue(
                    "개별평가 대상이 등록되었습니다. targetId=" + result.individualTargetId
                );
                scwin.loadIndividualEvalTargets();
            }

            // 개별평가 대상 삭제 후 상태문구를 갱신하고 목록을 다시 조회한다.
            function sbmDeleteIndividualEvalTarget_submitdone(e) {
                var response = JSON.parse(e.responseBody);
                if (!response.success) {
                    alert(response.error ? response.error.message : "개별평가 대상 삭제 중 오류가 발생했습니다.");
                    return;
                }

                $p.getComponentById("txtIndividualEvalStatus").setValue("개별평가 대상이 삭제되었습니다.");
                scwin.loadIndividualEvalTargets();
            }
        ]]></w2:script>
    </w2:head>

    <w2:body ev:onload="scwin.onload()">
        <w2:group style="padding:24px;">
            <!-- 화면 제목 및 학습 목적 안내 -->
            <w2:group style="margin-bottom:16px;">
                <w2:textbox value="충당금 WebSquare 학습 화면" style="font-size:24px;font-weight:bold;"/>
                <w2:textbox value="배치 실행 -> step 이력 -> 계약별 충당금 결과 -> 요약 조회 흐름을 WebSquare 기준으로 학습한다."
                            style="margin-top:8px;color:#666666;"/>
            </w2:group>

            <!-- 충당금 배치 실행 및 배치실행번호 확인 영역 -->
            <w2:group style="margin-bottom:16px;">
                <w2:textbox value="1. 배치 실행" style="font-size:18px;font-weight:bold;"/>
                <w2:inputCalendar id="iptBaseDate" dataType="date" value="2026-01-10" style="width:140px;"/>
                <w2:trigger label="배치 실행" ev:onclick="scwin.runBatch();"/>
                <w2:input id="iptBatchRunNo" style="width:220px;" placeholder="배치실행번호"/>
                <w2:trigger label="Step 조회" ev:onclick="scwin.loadStepHistory();"/>
                <w2:gridView id="grdBatchRunResult" dataList="dmBatchRunResult" style="width:100%;height:110px;margin-top:12px;">
                    <w2:columns>
                        <w2:column id="batchRunNo" width="180" headerValue="배치실행번호"/>
                        <w2:column id="baseDate" width="100" headerValue="기준일자"/>
                        <w2:column id="statusCode" width="90" headerValue="상태"/>
                        <w2:column id="targetCount" width="80" headerValue="대상건수"/>
                        <w2:column id="processedCount" width="80" headerValue="처리건수"/>
                    </w2:columns>
                </w2:gridView>
            </w2:group>

            <!-- 배치 이력 / 계약 조회 / 요약 조회에 공통으로 쓰는 조회 조건 영역 -->
            <w2:group style="margin-bottom:16px;">
                <w2:textbox value="2. 조회 조건" style="font-size:18px;font-weight:bold;"/>
                <w2:inputCalendar id="iptHistoryDate" dataType="date" value="2026-01-10" style="width:140px;"/>
                <w2:trigger label="배치이력 조회" ev:onclick="scwin.loadBatchHistory();"/>
                <w2:input id="iptContractNo" style="width:180px;" value="LN-2026-000001"/>
                <w2:trigger label="계약 조회" ev:onclick="scwin.loadContractResult();"/>
                <w2:inputCalendar id="iptSummaryDate" dataType="date" value="2026-01-10" style="width:140px;"/>
                <w2:trigger label="요약 조회" ev:onclick="scwin.loadSummary();"/>
                <w2:inputCalendar id="iptSegmentSummaryDate" dataType="date" value="2026-01-10" style="width:140px;"/>
                <w2:trigger label="세그먼트 요약 조회" ev:onclick="scwin.loadSegmentSummary();"/>
            </w2:group>

            <!-- 배치 헤더 이력과 Step 이력을 나란히 확인하는 영역 -->
            <w2:group style="margin-bottom:16px;">
                <w2:textbox value="배치 이력 / Step 이력" style="font-size:16px;font-weight:bold;"/>
                <w2:gridView id="grdBatchHistory" dataList="dlBatchHistory" style="width:100%;height:180px;">
                    <w2:columns>
                        <w2:column id="batchRunNo" width="180" headerValue="배치실행번호"/>
                        <w2:column id="baseDate" width="100" headerValue="기준일자"/>
                        <w2:column id="batchType" width="80" headerValue="유형"/>
                        <w2:column id="statusCode" width="90" headerValue="상태"/>
                        <w2:column id="targetCount" width="80" headerValue="대상건수"/>
                        <w2:column id="processedCount" width="80" headerValue="처리건수"/>
                        <w2:column id="errorCount" width="80" headerValue="오류건수"/>
                    </w2:columns>
                </w2:gridView>

                <w2:gridView id="grdStepHistory" dataList="dlStepHistory" style="width:100%;height:180px;margin-top:12px;">
                    <w2:columns>
                        <w2:column id="stepName" width="160" headerValue="단계명"/>
                        <w2:column id="statusCode" width="90" headerValue="상태"/>
                        <w2:column id="processedCount" width="80" headerValue="처리건수"/>
                        <w2:column id="startedAt" width="170" headerValue="시작일시"/>
                        <w2:column id="finishedAt" width="170" headerValue="종료일시"/>
                    </w2:columns>
                </w2:gridView>
            </w2:group>

            <!-- 개별평가 대상 관리: 참고 계약 조회 -> 등록 입력 -> 목록 조회 / 삭제 -->
            <w2:group style="margin-bottom:16px;">
                <w2:textbox value="개별평가 대상 관리" style="font-size:16px;font-weight:bold;"/>
                <w2:inputCalendar id="iptIeBaseDate" dataType="date" value="2026-01-10" style="width:140px;"/>
                <w2:input id="iptIeContractNo" style="width:180px;" value="LN-2026-000001"/>
                <w2:trigger label="계약 조회" ev:onclick="scwin.loadIndividualEvalContract();"/>
                <w2:trigger label="대상 목록 조회" ev:onclick="scwin.loadIndividualEvalTargets();"/>
                <w2:textbox id="txtIndividualEvalStatus" value="계약 조회 전입니다." style="margin-top:8px;color:#666666;"/>

                <w2:group style="margin-top:12px;">
                    <w2:textbox value="참고 계약정보" style="font-size:14px;font-weight:bold;"/>
                    <w2:group style="margin-top:8px;">
                        <w2:textbox value="기준일자" style="width:90px;display:inline-block;"/>
                        <w2:textbox id="txtIeBaseDate" value="" style="width:150px;display:inline-block;"/>
                        <w2:textbox value="계약번호" style="width:90px;display:inline-block;margin-left:16px;"/>
                        <w2:textbox id="txtIeContractNo" value="" style="width:180px;display:inline-block;"/>
                        <w2:textbox value="고객명" style="width:90px;display:inline-block;margin-left:16px;"/>
                        <w2:textbox id="txtIeCustomerName" value="" style="width:140px;display:inline-block;"/>
                        <w2:textbox value="상품코드" style="width:90px;display:inline-block;margin-left:16px;"/>
                        <w2:textbox id="txtIeProductCode" value="" style="width:140px;display:inline-block;"/>
                    </w2:group>
                    <w2:group style="margin-top:8px;">
                        <w2:textbox value="Stage" style="width:90px;display:inline-block;"/>
                        <w2:textbox id="txtIeStageCode" value="" style="width:100px;display:inline-block;"/>
                        <w2:textbox value="Stage 사유" style="width:90px;display:inline-block;margin-left:16px;"/>
                        <w2:textbox id="txtIeStageReason" value="" style="width:180px;display:inline-block;"/>
                        <w2:textbox value="장부가" style="width:90px;display:inline-block;margin-left:16px;"/>
                        <w2:textbox id="txtIeCarryingAmount" value="" style="width:140px;display:inline-block;"/>
                        <w2:textbox value="EAD" style="width:90px;display:inline-block;margin-left:16px;"/>
                        <w2:textbox id="txtIeEadAmount" value="" style="width:140px;display:inline-block;"/>
                    </w2:group>
                    <w2:group style="margin-top:8px;">
                        <w2:textbox value="1년 PD" style="width:90px;display:inline-block;"/>
                        <w2:textbox id="txtIeOneYearPdRate" value="" style="width:120px;display:inline-block;"/>
                        <w2:textbox value="Lifetime PD" style="width:90px;display:inline-block;margin-left:16px;"/>
                        <w2:textbox id="txtIeLifetimePdRate" value="" style="width:120px;display:inline-block;"/>
                        <w2:textbox value="LGD" style="width:90px;display:inline-block;margin-left:16px;"/>
                        <w2:textbox id="txtIeLgdRate" value="" style="width:120px;display:inline-block;"/>
                        <w2:textbox value="ECL" style="width:90px;display:inline-block;margin-left:16px;"/>
                        <w2:textbox id="txtIeEclAmount" value="" style="width:140px;display:inline-block;"/>
                    </w2:group>
                </w2:group>

                <w2:group style="margin-top:12px;">
                    <w2:textbox value="개별평가 등록 입력" style="font-size:14px;font-weight:bold;"/>
                    <w2:group style="margin-top:8px;">
                        <w2:textbox value="평가사유코드" style="width:110px;display:inline-block;"/>
                        <w2:input id="iptEvalReasonCode" style="width:180px;" value="DEFAULT" placeholder="DEFAULT / DELINQ / RESTRUCT / MANUAL / WATCH"/>
                        <w2:textbox value="평가사유상세" style="width:110px;display:inline-block;margin-left:16px;"/>
                        <w2:input id="iptEvalReasonDetail" style="width:240px;" placeholder="예: 수동 개별평가 대상"/>
                    </w2:group>
                    <w2:group style="margin-top:8px;">
                        <w2:textbox value="예상회수금액" style="width:110px;display:inline-block;"/>
                        <w2:input id="iptRecoveryExpectedAmt" style="width:180px;" placeholder="예: 5000000"/>
                        <w2:textbox value="할인율" style="width:110px;display:inline-block;margin-left:16px;"/>
                        <w2:input id="iptDiscountRate" style="width:180px;" placeholder="예: 0.0450"/>
                        <w2:trigger label="등록" ev:onclick="scwin.registerIndividualEvalTarget();" style="margin-left:16px;"/>
                        <w2:trigger label="삭제" ev:onclick="scwin.deleteIndividualEvalTarget();" style="margin-left:8px;"/>
                    </w2:group>
                </w2:group>

                <w2:group style="margin-top:12px;">
                    <w2:textbox value="개별평가 대상 목록" style="font-size:14px;font-weight:bold;"/>
                    <w2:gridView id="grdIndividualEvalTargets" dataList="dlIndividualEvalTargets" style="width:100%;height:180px;margin-top:8px;">
                        <w2:columns>
                            <w2:column id="individualTargetId" width="90" headerValue="대상ID"/>
                            <w2:column id="baseDate" width="100" headerValue="기준일자"/>
                            <w2:column id="contractNo" width="140" headerValue="계약번호"/>
                            <w2:column id="customerName" width="100" headerValue="고객명"/>
                            <w2:column id="productCode" width="100" headerValue="상품코드"/>
                            <w2:column id="evalReasonCode" width="110" headerValue="평가사유코드"/>
                            <w2:column id="evalReasonDetail" width="160" headerValue="평가사유상세"/>
                            <w2:column id="recoveryExpectedAmt" width="120" headerValue="예상회수금액"/>
                            <w2:column id="discountRate" width="100" headerValue="할인율"/>
                            <w2:column id="activeYn" width="80" headerValue="사용여부"/>
                        </w2:columns>
                    </w2:gridView>
                </w2:group>
            </w2:group>

            <!-- 계약별 충당금 결과 조회 영역 -->
            <w2:group style="margin-bottom:16px;">
                <w2:textbox value="계약별 충당금 결과" style="font-size:16px;font-weight:bold;"/>
                <w2:gridView id="grdContractResults" dataList="dlContractResults" style="width:100%;height:220px;">
                    <w2:columns>
                        <w2:column id="contractNo" width="140" headerValue="계약번호"/>
                        <w2:column id="customerName" width="100" headerValue="고객명"/>
                        <w2:column id="productCode" width="100" headerValue="상품코드"/>
                        <w2:column id="stageCode" width="80" headerValue="Stage"/>
                        <w2:column id="stageReason" width="120" headerValue="Stage 사유"/>
                        <w2:column id="carryingAmount" width="110" headerValue="장부가"/>
                        <w2:column id="eadAmount" width="110" headerValue="EAD"/>
                        <w2:column id="oneYearPdRate" width="90" headerValue="1년PD"/>
                        <w2:column id="lifetimePdRate" width="100" headerValue="LifetimePD"/>
                        <w2:column id="lgdRate" width="90" headerValue="LGD"/>
                        <w2:column id="recoveryRate" width="90" headerValue="회수율"/>
                        <w2:column id="eclAmount" width="110" headerValue="ECL"/>
                    </w2:columns>
                </w2:gridView>
            </w2:group>

            <!-- 기준일자별 상품 / Stage 요약 영역 -->
            <w2:group style="margin-bottom:16px;">
                <w2:textbox value="기준일자별 충당금 요약" style="font-size:16px;font-weight:bold;"/>
                <w2:gridView id="grdSummary" dataList="dlSummary" style="width:100%;height:180px;">
                    <w2:columns>
                        <w2:column id="baseDate" width="100" headerValue="기준일자"/>
                        <w2:column id="productCode" width="120" headerValue="상품코드"/>
                        <w2:column id="stageCode" width="80" headerValue="Stage"/>
                        <w2:column id="contractCount" width="80" headerValue="계약건수"/>
                        <w2:column id="totalCarryingAmount" width="120" headerValue="장부가합계"/>
                        <w2:column id="totalEadAmount" width="120" headerValue="EAD합계"/>
                        <w2:column id="totalEclAmount" width="120" headerValue="ECL합계"/>
                    </w2:columns>
                </w2:gridView>
            </w2:group>

            <!-- 기준일자별 고객유형 / 세그먼트 / Stage 요약 영역 -->
            <w2:group>
                <w2:textbox value="세그먼트별 충당금 요약" style="font-size:16px;font-weight:bold;"/>
                <w2:gridView id="grdSegmentSummary" dataList="dlSegmentSummary" style="width:100%;height:180px;">
                    <w2:columns>
                        <w2:column id="baseDate" width="100" headerValue="기준일자"/>
                        <w2:column id="customerType" width="110" headerValue="고객유형"/>
                        <w2:column id="segmentCode" width="120" headerValue="세그먼트코드"/>
                        <w2:column id="stageCode" width="80" headerValue="Stage"/>
                        <w2:column id="contractCount" width="80" headerValue="계약건수"/>
                        <w2:column id="totalCarryingAmount" width="120" headerValue="장부가합계"/>
                        <w2:column id="totalEadAmount" width="120" headerValue="EAD합계"/>
                        <w2:column id="totalEclAmount" width="120" headerValue="ECL합계"/>
                    </w2:columns>
                </w2:gridView>
            </w2:group>
        </w2:group>
    </w2:body>
</w2:root>
